# ============================================================
# Closira — Environment Variables
#
# 1. Copy this file: cp .env.example .env
# 2. Fill in GROQ_API_KEY
# 3. Never commit .env to version control
# ============================================================

# ── Required ────────────────────────────────────────────────
# Get your key from https://console.groq.com/
GROQ_API_KEY=gsk_your_key_here

# ── Optional ────────────────────────────────────────────────
# Model to use. llama3-70b-8192 is best quality.
# Use llama3-8b-8192 for lower latency/cost during development.
GROQ_MODEL=llama3-70b-8192

# Port the API server binds to on the host machine.
HOST_PORT=8000

# Comma-separated list of allowed frontend origins for CORS.
# Use * only for local dev. Set your real domain(s) for production.
# Example: ALLOWED_ORIGINS=https://app.yourdomain.com,https://staging.yourdomain.com
ALLOWED_ORIGINS=*
